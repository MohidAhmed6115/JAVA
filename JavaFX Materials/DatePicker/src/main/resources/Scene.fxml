   <children>
      <DatePicker fx:id="myDatePicker" layoutX="195.0" layoutY="211.0" onAction="#getDate" prefHeight="36.0" prefWidth="210.0" promptText="Enter a date" />
      <Label fx:id="myLabel" alignment="CENTER" layoutY="128.0" prefHeight="17.0" prefWidth="604.0" text="Label">
         <font>
            <Font size="36.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
