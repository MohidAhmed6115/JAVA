<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller">
   <children>
      <Button layoutX="274.0" layoutY="25.0" mnemonicParsing="false" onAction="#up" text="UP" />
      <Button layoutX="527.0" layoutY="188.0" mnemonicParsing="false" onAction="#right" text="RIGHT" />
      <Button layoutX="23.0" layoutY="188.0" mnemonicParsing="false" onAction="#left" text="LEFT" />
      <Button layoutX="274.0" layoutY="361.0" mnemonicParsing="false" onAction="#down" text="DOWN" />
      <Circle fx:id="myCircle" fill="DODGERBLUE" layoutX="300.0" layoutY="201.0" radius="100.0" stroke="BLACK" strokeType="INSIDE" />
   </children>
</AnchorPane>
