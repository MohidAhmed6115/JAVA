  "Java Validate Method": {
    "body": [
      "public static int validateIntInput(Scanner in, int min, int max) {",
      "  while (true) {",
      "      try {",
      "          int response = in.nextInt();",
      "          if (response >= min && response <= max) {",
      "              return response;",
      "          }",
      "          System.out.print(\"Invalid Input! Please enter from above options: \");",
      "      } catch (InputMismatchException e) {",
      "          System.out.println(\"Invalid Input! Please enter an integer!\");",
      "          in.nextLine();",
      "      }",
      "  }",
      "}"
    ],
    "description": "Java validate method to validate int input",
    "prefix": "validate"
  }
